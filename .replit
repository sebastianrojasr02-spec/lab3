modules = ["bash", "nix"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run HashMap"

[[workflows.workflow]]
name = "Run HashMap"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc -g main.c hashmap.c -o main -lm && ./main"

[workflows.workflow.metadata]
outputType = "console"
